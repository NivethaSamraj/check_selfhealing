import { Page, Locator } from '@playwright/test';
import { getElement } from '../db/elementRepo';
import { getAILocator } from '../ai/aiHealing';
import { saveHealingLog } from '../db/healingRepo';
import { getMinimalFullDOM } from '../../utils/selfHealing';
import { HealingLogger } from '../../utils/healingLogger';
import { containsDynamicId } from '../../utils/selfHealing';
import { beginFlow, logStep, endFlow } from '../../src/reporting/sink';

//  TYPE FIRST
type FallbackResult = {
  locator: Locator;
  usedStrategy: string;
};

// Read once at module load. Healing (AI tier) is ON by default;
// only the exact string "true" disables it. "false"/unset = active.
const HEALING_DISABLED = process.env.DISABLE_HEALING === 'true';

export async function findWithFallback(
  page: Page,
  elementName: string,
  primaryLocator: Locator,
  testName: string = 'default-test'
): Promise<FallbackResult> {

  const attempted: string[] = [];

  // =========================================================
  // START FLOW RECORDING (HTML report)
  // =========================================================
  beginFlow(elementName, testName, page.url());

  // =========================================================
  // START LOGGING
  // =========================================================

  HealingLogger.info('Test', testName);
  HealingLogger.info('Element', elementName);
  HealingLogger.info('Page', page.url());

  HealingLogger.info('AI SELF-HEALING STARTED', 'Azure_OpenAI');

  // =========================================================
  // STEP 1 — FETCH ELEMENT FROM DB
  // =========================================================

  HealingLogger.subSection(
    'STEP 1 — DATABASE PRIMARY LOCATOR'
  );

  const element = await getElement(elementName);

  if (!element) {

    HealingLogger.fail(
      `No locator data found for ${elementName}`
    );

    // record the dead-end before throwing
    logStep({
      tier: 'db',
      action: 'Fetch element from DB',
      status: 'failed',
      reason: `No locator data found for ${elementName}`,
    });
    endFlow({
      finalTier: null,
      finalLocator: null,
      healed: false,
      writtenBack: false,
    });

    throw new Error(
      `No locator data found for ${elementName}`
    );
  }

  const dbPrimaryLocatorStr = element.primary_locator;

  if (dbPrimaryLocatorStr) {

    HealingLogger.info(
      'Trying',
      dbPrimaryLocatorStr
    );

    const dbStart = Date.now();

    const dbPrimary = buildLocator(
      page,
      dbPrimaryLocatorStr
    );

    if (
      dbPrimary &&
      await isValidLocator(dbPrimary)
    ) {

      HealingLogger.success(
        `DB Primary locator worked`
      );

      logStep({
        tier: 'db',
        action: 'DB primary locator',
        locator: dbPrimaryLocatorStr,
        status: 'success',
        durationMs: Date.now() - dbStart,
      });

      await saveHealingLog({
        elementName,
        testName,
        failedLocator: 'POM_PRIMARY',
        attemptedLocators: attempted,
        healedLocator: dbPrimaryLocatorStr,
        strategy: 'db-primary',
        status: 'HEALED',
        errorMessage: null,
      });

      endFlow({
        finalTier: 'db',
        finalLocator: dbPrimaryLocatorStr,
        healed: false,
        writtenBack: false,
      });

      return {
        locator: resolveToSingle(dbPrimary),
        usedStrategy: 'db-primary',
      };
    }

    attempted.push('db-primary');

    logStep({
      tier: 'db',
      action: 'DB primary locator',
      locator: dbPrimaryLocatorStr,
      status: 'failed',
      reason: 'Locator built but matched 0 / >1 or not visible',
      durationMs: Date.now() - dbStart,
    });

    HealingLogger.fail(
      `DB Primary locator failed`
    );
  } else {

    logStep({
      tier: 'db',
      action: 'DB primary locator',
      status: 'skipped',
      reason: 'No primary_locator stored for element',
    });
  }

  // =========================================================
  // STEP 2 — SMART LOCATOR FALLBACK
  // =========================================================

  HealingLogger.subSection(
    'STEP 2 — SMART LOCATOR FALLBACK'
  );

  const smartLocators =
    typeof element.smart_locators === 'string'
      ? JSON.parse(element.smart_locators)
      : element.smart_locators;

  const priority = [
    'role',
    'testId',
    'label',
    'placeholder',
    'text',
    'alt',
    'title',
    'css',
    'xpath'
  ];

  for (const key of priority) {

    const locatorStr = smartLocators?.[key];

    if (!locatorStr) continue;

    attempted.push(key);

    HealingLogger.info(
      'Strategy',
      key
    );

    HealingLogger.info(
      'Locator',
      locatorStr
    );

    const smartStart = Date.now();

    const built = buildLocator(
      page,
      locatorStr
    );

    if (!built) {

      HealingLogger.fail(
        'Failed to build locator'
      );

      logStep({
        tier: 'smart',
        action: `Smart: ${key}`,
        locator: locatorStr,
        status: 'failed',
        reason: 'Failed to build locator',
        durationMs: Date.now() - smartStart,
      });

      continue;
    }

    const valid = await isValidLocator(built);

    HealingLogger.info(
      'Result',
      valid ? 'SUCCESS' : 'FAILED'
    );

    if (valid) {

      HealingLogger.success(
        `Element healed using ${key}`
      );

      logStep({
        tier: 'smart',
        action: `Smart: ${key}`,
        locator: locatorStr,
        status: 'success',
        durationMs: Date.now() - smartStart,
      });

      await saveHealingLog({
        elementName,
        testName,
        failedLocator: primaryLocator,
        attemptedLocators: attempted,
        healedLocator: locatorStr,
        strategy: key,
        status: 'HEALED',
        errorMessage: null,
      });

      HealingLogger.section(
        'HEALING COMPLETED'
      );

      endFlow({
        finalTier: 'smart',
        finalLocator: locatorStr,
        healed: false,
        writtenBack: false,
      });

      return {
        locator: resolveToSingle(built),
        usedStrategy: key,
      };
    }

    logStep({
      tier: 'smart',
      action: `Smart: ${key}`,
      locator: locatorStr,
      status: 'failed',
      reason: 'Matched 0 / >1 elements or not visible',
      durationMs: Date.now() - smartStart,
    });
  }

  // =========================================================
  // STEP 3 — AI HEALING
  // =========================================================

  // DISABLE_HEALING guard — skip the AI tier entirely when set.
  // DB-primary and smart-locator tiers above still run normally.
  if (HEALING_DISABLED) {

    HealingLogger.subSection(
      'STEP 3 — AI HEALING SKIPPED (DISABLE_HEALING=true)'
    );

    logStep({
      tier: 'ai',
      action: 'AI healing',
      status: 'skipped',
      reason: 'DISABLE_HEALING=true — AI tier bypassed',
    });

    await saveHealingLog({
      elementName,
      testName,
      failedLocator: primaryLocator.toString(),
      attemptedLocators: attempted,
      healedLocator: null,
      strategy: 'AI',
      status: 'FAILED',
      errorMessage: 'AI healing disabled (DISABLE_HEALING=true)',
    });

    endFlow({
      finalTier: null,
      finalLocator: null,
      healed: false,
      writtenBack: false,
    });

    throw new Error(
      `DB and smart locators failed for ${elementName}; ` +
      `AI healing disabled (DISABLE_HEALING=true).`
    );
  }

  HealingLogger.subSection(
    'STEP 3 — AI HEALING'
  );

  HealingLogger.ai(
    'Collecting screenshots and DOM context'
  );

  const aiStart = Date.now();

  try {

    // =========================================================
    // CURRENT SCREENSHOT
    // =========================================================

    const screenshotBuffer =
      await page.screenshot({
        fullPage: true
      });

    const currentPageScreenshot =
      screenshotBuffer.toString('base64');

    // =========================================================
    // OLD ELEMENT SCREENSHOT
    // =========================================================

    const oldElementScreenshot =
      element?.element_screenshot
        ? Buffer
          .from(element.element_screenshot)
          .toString('base64')
        : null;

    // =========================================================
    // OLD FULL PAGE SCREENSHOT
    // =========================================================

    const oldPageScreenshot =
      element?.full_page_screenshot
        ? Buffer
          .from(element.full_page_screenshot)
          .toString('base64')
        : null;

    // =========================================================
    // OLD OUTER HTML
    // =========================================================

    const oldOuterHTML =
      element?.outer_html || '';

    if (!oldOuterHTML) {

      HealingLogger.warn(
        'No stored outerHTML found'
      );
    }

    HealingLogger.ai(
      'Sending healing request to AI model'
    );

    // =========================================================
    // AI CALL
    // =========================================================

    const aiResponse = await getAILocator({
      elementName,
      failedLocator: primaryLocator.toString(),
      smartLocators,
      oldOuterHTML: element.outer_html,
      oldDOM: element.full_dom,
      newDOM: await getMinimalFullDOM(page),
      currentPageScreenshot,
      oldPageScreenshot,
      oldElementScreenshot,
      meta: element?.meta || {},
    });

    // =========================================================
    // AI RESPONSE LOGGING
    // =========================================================

    HealingLogger.ai(
      `Locator      : ${aiResponse?.locator}`
    );

    HealingLogger.ai(
      `Confidence   : ${aiResponse?.confidence}`
    );

    HealingLogger.ai(
      `Reason       : ${aiResponse?.reason}`
    );

    // =========================================================
    // VALIDATE AI RESPONSE
    // =========================================================

    if (
      !aiResponse ||
      !aiResponse.locator
    ) {

      throw new Error(
        'AI returned empty or invalid response'
      );
    }

    // =========================================================
    // CONFIDENCE CHECK
    // =========================================================

    if (aiResponse.confidence < 0.7) {

      throw new Error(
        `Low confidence AI response: ${aiResponse.confidence}`
      );
    }

    // =========================================================
    // BUILD AI LOCATOR
    // =========================================================

    if (
      containsDynamicId(
        aiResponse.locator
      )
    ) {

      throw new Error(
        'AI returned dynamic locator'
      );
    }

    const aiLocator = buildLocator(
      page,
      aiResponse.locator
    );

    if (!aiLocator) {

      throw new Error(
        'Failed to build locator from AI response'
      );
    }

    // =========================================================
    // VALIDATE AI LOCATOR
    // =========================================================

    const isValid =
      await isValidLocator(aiLocator);

    if (isValid) {

      HealingLogger.subSection(
        'HEALING SUCCESS'
      );

      HealingLogger.success(
        'AI locator validated successfully'
      );

      HealingLogger.info(
        'Final Locator',
        aiResponse.locator
      );

      HealingLogger.info(
        'Confidence',
        aiResponse.confidence
      );

      logStep({
        tier: 'ai',
        action: 'AI heal vs live DOM',
        locator: aiResponse.locator,
        status: 'success',
        reason: aiResponse.reason,
        confidence: aiResponse.confidence,
        durationMs: Date.now() - aiStart,
      });

      await saveHealingLog({
        elementName,
        testName,
        failedLocator: primaryLocator.toString(),
        attemptedLocators: attempted,
        healedLocator: aiResponse.locator,
        strategy: 'AI',
        status: 'AI_HEALED',
        errorMessage: null,
      });

      HealingLogger.section(
        'HEALING COMPLETED'
      );

      endFlow({
        finalTier: 'ai',
        finalLocator: aiResponse.locator,
        healed: true,
        writtenBack: false,
      });

      return {
        locator: resolveToSingle(aiLocator),
        usedStrategy: 'AI',
      };
    }

    throw new Error(
      'AI locator is not valid on current page'
    );

  } catch (error: any) {

    HealingLogger.subSection(
      'HEALING FAILED'
    );

    HealingLogger.fail(
      error?.message || 'Unknown healing error'
    );

    logStep({
      tier: 'ai',
      action: 'AI heal vs live DOM',
      status: 'failed',
      reason: error?.message || 'Unknown healing error',
      durationMs: Date.now() - aiStart,
    });

    await saveHealingLog({
      elementName,
      testName,
      failedLocator: primaryLocator.toString(),
      attemptedLocators: attempted,
      healedLocator: null,
      strategy: 'AI',
      status: 'FAILED',
      errorMessage: error?.message || 'Unknown error',
    });

    endFlow({
      finalTier: null,
      finalLocator: null,
      healed: false,
      writtenBack: false,
    });

    throw new Error(
      `All locator strategies including AI failed for ${elementName}`
    );
  }
}

/* ------------------------------------------------------------------ *
 *  resolveToSingle
 *
 *  Narrows a locator that resolves to multiple elements down to one,
 *  covering two cases validated by isValidLocator:
 *    1. Twin case (e.g. Ann Taylor mobile + desktop search): several
 *       match but exactly one is visible → .filter(visible).first()
 *       picks the visible one.
 *    2. Soft-match case (e.g. product card image + title + quick-view
 *       links sharing one accessible name, all visible, all navigating
 *       to the same PDP): several visible → .first() takes the first
 *       visible match. isValidLocator has already logged this as a soft
 *       match for auditability.
 *  If the locator resolves to a single element this is effectively a
 *  no-op (the lone match is the first visible one).
 *
 *  NOTE: best-effort and synchronous-safe — returns a narrowed Locator
 *  without awaiting; the caller's action awaits it.
 * ------------------------------------------------------------------ */
export function resolveToSingle(locator: Locator): Locator {
  // Prefer the visible element among any twins. Playwright resolves
  // :visible filtering lazily at action time, so this is safe to return.
  return locator.filter({ visible: true }).first();
}

export function buildLocator(page: Page, locatorStr: string) {
  try {

    // ============================================================
    // PLAYWRIGHT-STYLE SELECTOR SUFFIXES (handle FIRST so they win
    // regardless of the leading character)
    //   - "<sel> >> nth=N"  → page.locator(sel).nth(N)
    //   - "<sel> >> visible=true" → page.locator(sel) + visible filter
    //   - "<sel>:visible"   → narrow to the visible match
    // These cannot be passed straight to page.locator as raw CSS,
    // which is why the old parser matched 0 elements for them.
    // ============================================================
    const nthMatch = locatorStr.match(/^(.*?)\s*>>\s*nth=(\d+)\s*$/i);
    if (nthMatch) {
      const base = nthMatch[1].trim();
      const idx = parseInt(nthMatch[2], 10);
      return buildBaseLocator(page, base).nth(idx);
    }

    const visibleEngineMatch = locatorStr.match(/^(.*?)\s*>>\s*visible=true\s*$/i);
    if (visibleEngineMatch) {
      const base = visibleEngineMatch[1].trim();
      return buildBaseLocator(page, base).filter({ visible: true }).first();
    }

    if (/:visible\s*$/i.test(locatorStr)) {
      const base = locatorStr.replace(/:visible\s*$/i, '').trim();
      return buildBaseLocator(page, base).filter({ visible: true }).first();
    }

    return buildBaseLocator(page, locatorStr);

  } catch (err) {
    console.log(
      "Failed to parse locator:",
      locatorStr
    );
    return null;
  }
}

/* ------------------------------------------------------------------ *
 *  buildBaseLocator — the original locator-string parser, unchanged in
 *  behaviour, factored out so the suffix handling above can reuse it.
 * ------------------------------------------------------------------ */
function buildBaseLocator(page: Page, locatorStr: string): Locator {

  // CSS
  if (
    locatorStr.startsWith("#") ||
    locatorStr.startsWith(".") ||
    locatorStr.startsWith("[")
  ) {
    return page.locator(locatorStr);
  }

  // XPath
  if (
    locatorStr.startsWith("//") ||
    locatorStr.startsWith("(//")
  ) {
    return page.locator(`xpath=${locatorStr}`);
  }

  // ---- getByRole ----
  // The AI may return either a quoted string name or a regex literal name:
  //   getByRole('link', { name: 'Add to bag' })
  //   getByRole('link', { name: /v-neck ruffle maxi dress/i })
  // The original parser only handled the quoted form, so regex names fell
  // through to page.locator() and crashed the CSS parser on the "{".

  // regex-name form first
  const roleRegexMatch = locatorStr.match(
    /getByRole\('([^']+)'\s*,\s*\{\s*name:\s*\/(.+?)\/([a-z]*)\s*\}/i
  );
  if (roleRegexMatch) {
    const re = new RegExp(roleRegexMatch[2], roleRegexMatch[3] || undefined);
    return page.getByRole(roleRegexMatch[1] as any, { name: re });
  }

  // quoted-string-name form (preserve exact:true when present)
  const roleMatch = locatorStr.match(
    /getByRole\('([^']+)'\s*,\s*\{\s*name:\s*'([^']+)'(?:\s*,\s*exact:\s*(true|false))?/
  );
  if (roleMatch) {
    const opts: any = { name: roleMatch[2] };
    if (roleMatch[3]) opts.exact = roleMatch[3] === 'true';
    return page.getByRole(roleMatch[1] as any, opts);
  }

  // bare getByRole('button') with no name
  const roleOnly = locatorStr.match(/getByRole\('([^']+)'\s*\)/);
  if (roleOnly) {
    return page.getByRole(roleOnly[1] as any);
  }

  // ---- getByText ----
  const textRegex = locatorStr.match(/getByText\(\/(.+?)\/([a-z]*)\)/i);
  if (textRegex) {
    return page.getByText(new RegExp(textRegex[1], textRegex[2] || undefined));
  }
  const textMatch = locatorStr.match(/getByText\('([^']+)'/);
  if (textMatch) {
    return page.getByText(textMatch[1]);
  }

  // ---- getByLabel ----
  const labelRegex = locatorStr.match(/getByLabel\(\/(.+?)\/([a-z]*)\)/i);
  if (labelRegex) {
    return page.getByLabel(new RegExp(labelRegex[1], labelRegex[2] || undefined));
  }
  const labelMatch = locatorStr.match(/getByLabel\('([^']+)'/);
  if (labelMatch) {
    return page.getByLabel(labelMatch[1]);
  }

  // ---- getByPlaceholder ----
  const phRegex = locatorStr.match(/getByPlaceholder\(\/(.+?)\/([a-z]*)\)/i);
  if (phRegex) {
    return page.getByPlaceholder(new RegExp(phRegex[1], phRegex[2] || undefined));
  }
  const placeholderMatch = locatorStr.match(/getByPlaceholder\('([^']+)'/);
  if (placeholderMatch) {
    return page.getByPlaceholder(placeholderMatch[1]);
  }

  return page.locator(locatorStr);
}

// Validate locator safely.
//
// A locator is VALID when it resolves to exactly one element, OR when
// it resolves to several but exactly one of them is visible (the common
// "mobile + desktop twin" case). In the latter case the caller narrows
// to the visible element via resolveToSingle(), so validation must not
// reject it outright the way the old count>1 check did.
export async function isValidLocator(
  locator: Locator
): Promise<boolean> {
  try {

    const count = await locator.count();

    if (count === 0) {
      HealingLogger.warn(
        'Locator matched 0 elements'
      );
      return false;
    }

    if (count > 1) {
      // Count how many of the matches are visible.
      const visibleCount = await countVisible(locator, count);

      if (visibleCount === 1) {
        HealingLogger.info(
          'Disambiguation',
          `Locator matched ${count} elements but exactly 1 is visible — accepting visible match`
        );
        return true;
      }

      if (visibleCount > 1) {
        // SOFT MATCH: several visible elements share this locator. This is
        // the product-card pattern (image link + title link + quick-view all
        // carry the same accessible name and all navigate to the same PDP).
        // resolveToSingle() will take .first(); we accept but flag it loudly
        // so it is auditable in reports rather than silently passing.
        HealingLogger.warn(
          `Locator matched ${count} elements (${visibleCount} visible) — ` +
          `SOFT MATCH, using .first(). Verify this is intended for this element.`
        );
        return true;
      }

      HealingLogger.warn(
        `Locator matched ${count} elements (0 visible) — ambiguous, rejecting`
      );
      return false;
    }

    await locator.waitFor({
      state: 'visible',
      timeout: 3000,
    });

    return true;

  } catch (error: any) {

    HealingLogger.warn(
      `Locator validation failed: ${error.message}`
    );

    return false;
  }
}

/* ------------------------------------------------------------------ *
 *  countVisible — how many of the N matched elements are visible.
 * ------------------------------------------------------------------ */
async function countVisible(locator: Locator, count: number): Promise<number> {
  let visible = 0;
  for (let i = 0; i < count; i++) {
    try {
      if (await locator.nth(i).isVisible()) visible++;
    } catch {
      /* ignore individual probe errors */
    }
  }
  return visible;
}

function escapeRegex(text: string): string {
  return text.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}
