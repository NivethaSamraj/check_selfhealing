  "description": "",
  "main": "index.js",
  "scripts": {
    "run:test": "npx playwright test test_scripts/Homepage.spec.ts --project=chrome",
    "generate-open-report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "clean:reports": "rimraf allure-report allure-results Screenshots && mkdir allure-report allure-results Screenshots",
    "tunnel": "LT --user %LT_USERNAME% --key %LT_ACCESS_KEY% --tunnelName test1",
    "lambda-tests": "npx playwright test test_scripts/SampleSuite.spec.ts --config=./lambdatest.config.ts & npx playwright test report/finalise.spec.ts",
    "run:show-trace": "npx playwright show-trace test-results",
    "report": "allure generate allure-results --clean && allure open",
    "test": "playwright test 2>&1 | tee logs/run.log"
  },
