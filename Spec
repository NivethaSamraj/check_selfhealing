import { test, expect, Page, Frame, Locator } from '@playwright/test';

/**
 * Talbots End-to-End Checkout Flow — ISOLATED DIAGNOSTIC VERSION
 * ------------------------------------------------------------------
 * This is the "ran green" build:
 *   - DataLayer validation (validateCheckpoint) is COMMENTED OUT so the
 *     pure checkout flow can be proven on its own. The validation layer has
 *     no baseline config for dynamic runtime vars (tealium_random, mcmid,
 *     segmentID), so its assertions fail by default and mask real flow status.
 *   - Self-healing is DISABLED (guard below) so stale PostgreSQL locator
 *     overrides and the Azure OpenAI 401 don't inject misleading failures.
 *
 * ⚠ TEMPORARY DIAGNOSTIC STATE — do NOT commit over the real test.
 *   Re-enable validateCheckpoint + healing once baseline config and the
 *   Azure key are fixed.
 *
 * Self-contained: no external page objects / DB / brand override imports.
 *
 * Run headed + observable:
 *   DISABLE_HEALING=true npx playwright test DataLayerE2E_FullSample.spec.ts --headed
 */

// ---------------------------------------------------------------------------
// Self-healing kill switch (replaces framework fallbackEngine guard)
// ---------------------------------------------------------------------------
const DISABLE_HEALING = process.env.DISABLE_HEALING === 'true';
// In the framework, core/healing/fallbackEngine.ts -> findWithFallback() throws
// immediately when this is set, bypassing DB overrides + AI healing entirely.

// ---------------------------------------------------------------------------
// Environment
// ---------------------------------------------------------------------------
const BASE_URL = 'https://staging.talbots.com';
const BASIC_AUTH = { username: 'storefront', password: 'brand' };
const PROMO_CODE = 'SELFHEAL123';
const VALID_PHONE = '6175551234'; // valid 10-digit US number (9-digit was rejected)

const GUEST = {
  email: 'qa.guest@example.com',
  firstName: 'Guest',
  lastName: 'Tester',
  address1: '1 Federal St',
  city: 'Boston',
  state: 'MA',
  zip: '02110',
  phone: VALID_PHONE,
};

const REGISTERED = {
  email: 'qa.registered@example.com',
  password: 'Test@1234',
};

const CARD = {
  name: 'Guest Tester',
  number: '4111111111111111',
  expiry: '12/30',
  cvv: '123',
};

// ---------------------------------------------------------------------------
// Pacing — adjust in one place. Flow stays observable, not dead-fast.
// ---------------------------------------------------------------------------
const PACE = { micro: 600, short: 1200, medium: 2200, long: 3500 };

async function settle(page: Page, ms: number = PACE.short): Promise<void> {
  await page.waitForTimeout(ms);
}

async function humanScroll(page: Page, pixels: number, steps = 6): Promise<void> {
  const per = Math.round(pixels / steps);
  for (let i = 0; i < steps; i++) {
    await page.mouse.wheel(0, per);
    await page.waitForTimeout(250);
  }
}

/**
 * Aurus payment fields live inside <iframe id="frame_carddetails">.
 * Card name / number / expiry / CVV must be typed into THIS frame, not page.
 */
function cardFrame(page: Page): Frame {
  const frame = page.frame({ name: 'frame_carddetails' })
    ?? page.frames().find(f => f.url().includes('carddetails'))
    ?? page.frames().find(f => /aurus|card/i.test(f.url()));
  if (!frame) throw new Error('Aurus card iframe (frame_carddetails) not found');
  return frame;
}

/**
 * Try candidate locators in order, return first visible.
 * (Healing-framework-friendly, but here it's a plain fallback — no DB/AI.)
 */
async function firstVisible(page: Page, candidates: Locator[], timeout = 15000): Promise<Locator> {
  if (DISABLE_HEALING) {
    // healing path skipped — behaviour identical here, kept explicit for parity
  }
  const deadline = Date.now() + timeout;
  while (Date.now() < deadline) {
    for (const c of candidates) {
      if (await c.first().isVisible().catch(() => false)) return c.first();
    }
    await page.waitForTimeout(300);
  }
  throw new Error('No candidate locator became visible in time');
}

// ===========================================================================
// Shared flow steps (home -> PLP -> PDP -> cart -> checkout -> place order)
// ===========================================================================

async function landOnHome(page: Page): Promise<void> {
  await page.goto(BASE_URL, { waitUntil: 'domcontentloaded' });
  await settle(page, PACE.long);
  // await validateCheckpoint(page, 'home');   // DataLayer validation disabled
}

async function navigateToProductAndAddToBag(page: Page): Promise<void> {
  // Shop now
  const shopNow = await firstVisible(page, [
    page.getByRole('link', { name: /shop now/i }),
    page.getByRole('button', { name: /shop now/i }),
    page.locator('a:has-text("Shop Now")'),
  ]);
  await shopNow.click();
  await settle(page, PACE.long);
  // await validateCheckpoint(page, 'plp');    // DataLayer validation disabled

  await humanScroll(page, 1200);

  // First product on PLP
  const product = await firstVisible(page, [
    page.locator('.product-tile a').first(),
    page.locator('[data-product-id] a').first(),
    page.locator('a.product-link').first(),
  ]);
  await product.click();
  await settle(page, PACE.long);
  // await validateCheckpoint(page, 'pdp');    // DataLayer validation disabled

  // Select size
  const size = await firstVisible(page, [
    page.locator('.size-selector button:not([disabled])').first(),
    page.locator('[data-attr="size"] button:not([disabled])').first(),
    page.getByRole('button', { name: /^(XS|S|M|L|XL|\d+)$/ }).first(),
  ]);
  await size.click();
  await settle(page, PACE.short);

  // Add to bag
  const addToBag = await firstVisible(page, [
    page.locator('#add-to-cart'),
    page.getByRole('button', { name: /add to bag/i }),
    page.locator('button.add-to-cart'),
  ]);
  await addToBag.click();
  await settle(page, PACE.medium);
}

async function applyPromoAndCheckout(page: Page): Promise<void> {
  // View bag
  const viewBag = await firstVisible(page, [
    page.getByRole('link', { name: /view bag/i }),
    page.getByRole('button', { name: /view bag|checkout/i }),
    page.locator('a:has-text("View Bag")'),
  ]);
  await viewBag.click();
  await settle(page, PACE.long);
  // await validateCheckpoint(page, 'cart');   // DataLayer validation disabled

  // Promo code
  const promoInput = await firstVisible(page, [
    page.locator('#couponCode'),
    page.getByPlaceholder(/promo|coupon/i),
    page.locator('input[name*="coupon"]'),
  ]);
  await promoInput.fill(PROMO_CODE);
  const applyBtn = await firstVisible(page, [
    page.getByRole('button', { name: /^apply$/i }),
    page.locator('button.apply-coupon'),
  ]);
  await applyBtn.click();
  await settle(page, PACE.medium);

  // Proceed to checkout
  const checkout = await firstVisible(page, [
    page.getByRole('button', { name: /checkout/i }),
    page.getByRole('link', { name: /checkout/i }),
    page.locator('#checkout-btn'),
  ]);
  await checkout.click();
  await settle(page, PACE.long);
}

async function fillShipping(page: Page, who: typeof GUEST): Promise<void> {
  await page.locator('#email').fill(who.email).catch(() => {});
  await page.locator('#firstName').fill(who.firstName).catch(() => {});
  await page.locator('#lastName').fill(who.lastName).catch(() => {});
  await page.locator('#address1').fill(who.address1).catch(() => {});
  await page.locator('#city').fill(who.city).catch(() => {});
  await page.locator('#zipCode').fill(who.zip).catch(() => {});
  await page.locator('#phone').fill(who.phone);

  // Continue to billing/payment — duplicate #form-submit ids exist, pick visible
  const continueShipping = page
    .locator('#form-submit')
    .filter({ visible: true })
    .first();
  await continueShipping.click();
  await settle(page, PACE.long);
}

async function payWithCreditCard(page: Page): Promise<void> {
  // Select Credit Card radio — slow payment render, allow up to 60s
  const ccRadio = page.locator('#is-CREDIT_CARD');
  await ccRadio.waitFor({ state: 'visible', timeout: 60000 });
  await ccRadio.click();
  await settle(page, PACE.medium);

  // Aurus iframe fields — type slowly so tokenization registers each field
  const frame = cardFrame(page);
  await frame.locator('#cName').pressSequentially(CARD.name, { delay: 50 });
  await frame.locator('#cardNumber, [name="cardNumber"]').first()
    .pressSequentially(CARD.number, { delay: 50 });
  await frame.locator('#expiry, [name="expiry"]').first()
    .pressSequentially(CARD.expiry, { delay: 50 });
  const cvv = frame.locator('#secCode, [name="secCode"]').first();
  await cvv.pressSequentially(CARD.cvv, { delay: 50 });
  await cvv.blur(); // force Aurus tokenization before billing submit
  await settle(page, PACE.medium);

  // Continue for billing
  const continueBilling = page.locator('#billingSubmitBtn');
  await continueBilling.click();
  await settle(page, PACE.long);
}

async function placeOrder(page: Page): Promise<void> {
  const placeOrderBtn = page.getByRole('button', { name: /place order/i });
  await placeOrderBtn.scrollIntoViewIfNeeded();
  await placeOrderBtn.waitFor({ state: 'visible', timeout: 60000 });
  await placeOrderBtn.click();
  await settle(page, PACE.long);

  // Order confirmation
  await expect(
    page.getByText(/thank you|order (confirmed|number|placed)/i)
  ).toBeVisible({ timeout: 60000 });
  // await validateCheckpoint(page, 'confirmation');  // DataLayer validation disabled
}

// ===========================================================================
// Tests
// ===========================================================================

test.use({ httpCredentials: BASIC_AUTH });

test.describe('Talbots E2E Checkout (DataLayer validation isolated out)', () => {
  test('TC001 - Guest User E2E checkout', async ({ page }) => {
    await landOnHome(page);
    await navigateToProductAndAddToBag(page);
    await applyPromoAndCheckout(page);
    await fillShipping(page, GUEST);
    await payWithCreditCard(page);
    await placeOrder(page);
  });

  test('TC002 - Registered User E2E checkout', async ({ page }) => {
    await landOnHome(page);

    // Sign in
    const signIn = await firstVisible(page, [
      page.getByRole('link', { name: /sign in|log in/i }),
      page.locator('#sign-in'),
    ]);
    await signIn.click();
    await settle(page, PACE.medium);
    await page.locator('#login-email, #email').first().fill(REGISTERED.email);
    await page.locator('#login-password, #password').first().fill(REGISTERED.password);
    await page.getByRole('button', { name: /sign in|log in/i }).click();
    await settle(page, PACE.long);

    await navigateToProductAndAddToBag(page);
    await applyPromoAndCheckout(page);
    await fillShipping(page, GUEST); // reuse address; adjust if profile prefills

    // Registered flow uses the manual Credit Card path: Talbots saved card
    // renders no CVN field, so enterSecurityCodeForRegisteredUser is dropped.
    await payWithCreditCard(page);
    await placeOrder(page);
  });
});
